# ============================================================================
# LightBorrow 本地开发环境变量配置示例
# 复制此文件为 .env 并填入你的 API Key
# ============================================================================

# DeepSeek API（大模型）
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here

# 阿里云百炼 API（Embedding 模型）
EMBEDDING_API_KEY=sk-your-embedding-api-key-here

# PostgreSQL 密码（仅 docker profile 需要）
PG_PASSWORD=lightborrow
